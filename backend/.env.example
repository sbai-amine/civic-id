PORT=3000
DATABASE_URL=postgresql://civickey:civickey@localhost:5432/civickey
JWT_SECRET=use-long-random-hex-in-production
JWT_REFRESH_SECRET=another-long-random-secret
# Separate from JWT_SECRET: signs short-lived admin tokens (POST /auth/admin/token).
JWT_ADMIN_SECRET=separate-random-hex-different-from-JWT_SECRET
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
ADMIN_JWT_EXPIRES=1h
ADMIN_API_KEY=generate-a-long-random-key-for-admin-ops
ADMIN_NATIONAL_IDS=
# Optional legacy (deprecated): when true, also accepts old shared header
AGENT_SYNC_SECRET=

# Local signing keys (PEM). Leave empty to auto-generate ephemeral keys (dev only).
SIGNING_PRIVATE_KEY_PEM=
SIGNING_PUBLIC_KEY_PEM=

# Optional: `redis://` for distributed rate limits; omit to use in-memory
REDIS_URL=

# Browser origins (comma list). Empty = allow any origin (dev only).
CORS_ORIGINS=https://localhost:8090,http://localhost:8080

# Accept unsigned v1 QRs (userID+timestamp only) during app rollout. **0 in production.**
ALLOW_LEGACY_QR_PAYLOAD=0

# Rate limits
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20
ADMIN_TOKEN_RATE_LIMIT_MAX=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# HTTPS in production: terminate TLS at reverse proxy (nginx, Caddy, load balancer) or
# set NODE_HTTPS_KEY / NODE_HTTPS_CERT and run a TLS server � prefer proxy + HTTP upstream.
